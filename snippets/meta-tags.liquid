{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif

  comment — og:description con fallback inteligente por tipo de página + truncado a 155 chars
  endcomment
  if page_description != blank
    assign og_description = page_description | strip_html | truncate: 155
  elsif request.page_type == 'product'
    assign og_description = product.description | strip_html | truncate: 155
  elsif request.page_type == 'collection' and collection.description != blank
    assign og_description = collection.description | strip_html | truncate: 155
  elsif request.page_type == 'article'
    if article.excerpt != blank
      assign og_description = article.excerpt | strip_html | truncate: 155
    else
      assign og_description = article.content | strip_html | truncate: 155
    endif
  else
    assign og_description = shop.description | default: shop.name | truncate: 155
  endif

  comment — og:locale mapeado desde el locale del request
  endcomment
  case request.locale.iso_code
    when 'es'
      assign og_locale = 'es_CO'
    when 'en'
      assign og_locale = 'en_US'
    when 'pt-BR'
      assign og_locale = 'pt_BR'
    when 'pt-PT'
      assign og_locale = 'pt_PT'
    when 'fr'
      assign og_locale = 'fr_FR'
    when 'de'
      assign og_locale = 'de_DE'
    when 'it'
      assign og_locale = 'it_IT'
    else
      assign og_locale = 'es_CO'
  endcase

  comment — og:image:alt por tipo de página
  endcomment
  if request.page_type == 'product'
    assign og_image_alt = product.featured_image.alt | default: product.title
  elsif request.page_type == 'article'
    assign og_image_alt = article.image.alt | default: article.title
  elsif request.page_type == 'collection'
    assign og_image_alt = collection.image.alt | default: collection.title
  else
    assign og_image_alt = og_title
  endif
-%}

<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{{ og_description | escape }}">
<meta property="og:locale" content="{{ og_locale }}">

{%- if page_image -%}
  <meta property="og:image" content="https:{{ page_image | image_url: width: 1200 }}">
  <meta property="og:image:secure_url" content="https:{{ page_image | image_url: width: 1200 }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="{{ og_image_alt | escape }}">
  <meta name="twitter:image" content="https:{{ page_image | image_url: width: 1200 }}">
  <meta name="twitter:image:alt" content="{{ og_image_alt | escape }}">
{%- elsif settings.brand_image != blank -%}
  <meta property="og:image" content="https:{{ settings.brand_image | image_url: width: 1200 }}">
  <meta property="og:image:secure_url" content="https:{{ settings.brand_image | image_url: width: 1200 }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="{{ og_image_alt | escape }}">
  <meta name="twitter:image" content="https:{{ settings.brand_image | image_url: width: 1200 }}">
  <meta name="twitter:image:alt" content="{{ og_image_alt | escape }}">
{%- endif -%}

{%- if settings.social_instagram_link != blank -%}
  <meta property="og:see_also" content="{{ settings.social_instagram_link }}">
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta property="og:price:amount" content="{{ product.price | money_without_currency | strip_html }}">
  <meta property="og:price:currency" content="{{ cart.currency.iso_code }}">
{%- endif -%}

{%- if request.page_type == 'article' -%}
  <meta property="article:published_time" content="{{ article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' }}">
  {%- if article.user.name != blank -%}
    <meta property="article:author" content="{{ article.user.name | escape }}">
  {%- endif -%}
  {%- if blog.title != blank -%}
    <meta property="article:section" content="{{ blog.title | escape }}">
  {%- endif -%}
  {%- for tag in article.tags -%}
    <meta property="article:tag" content="{{ tag | escape }}">
  {%- endfor -%}
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta name="twitter:site" content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}">
{%- endif -%}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | escape }}">
<meta name="twitter:description" content="{{ og_description | escape }}">
