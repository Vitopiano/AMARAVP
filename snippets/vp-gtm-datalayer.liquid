{% comment %} VP — GA4 e-commerce dataLayer events (server-rendered) {% endcomment %}
<script>
  window.dataLayer = window.dataLayer || [];

  {% if request.page_type == 'product' %}

  window.dataLayer.push({ ecommerce: null });
  window.dataLayer.push({
    event: 'view_item',
    ecommerce: {
      currency: {{ shop.currency | json }},
      value: {{ product.selected_or_first_available_variant.price | divided_by: 100.0 }},
      items: [{
        item_id: {{ product.selected_or_first_available_variant.sku | default: product.selected_or_first_available_variant.id | json }},
        item_name: {{ product.title | json }},
        item_brand: {{ product.vendor | json }},
        item_category: {{ product.type | json }},
        item_variant: {{ product.selected_or_first_available_variant.title | json }},
        price: {{ product.selected_or_first_available_variant.price | divided_by: 100.0 }},
        quantity: 1
      }]
    }
  });

  {% comment %} Expose variant data for JS-side add_to_cart event {% endcomment %}
  window.vpVariants = {
    {% for variant in product.variants %}
    "{{ variant.id }}": {
      sku: {{ variant.sku | default: variant.id | json }},
      title: {{ variant.title | json }},
      price: {{ variant.price | divided_by: 100.0 }},
      product_title: {{ product.title | json }},
      product_vendor: {{ product.vendor | json }},
      product_type: {{ product.type | json }}
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  };

  {% elsif request.page_type == 'collection' %}

  window.dataLayer.push({ ecommerce: null });
  window.dataLayer.push({
    event: 'view_item_list',
    ecommerce: {
      item_list_id: {{ collection.handle | json }},
      item_list_name: {{ collection.title | json }},
      items: [
        {% for product in collection.products limit: 20 %}
        {
          item_id: {{ product.selected_or_first_available_variant.sku | default: product.selected_or_first_available_variant.id | json }},
          item_name: {{ product.title | json }},
          item_brand: {{ product.vendor | json }},
          item_category: {{ product.type | json }},
          price: {{ product.price | divided_by: 100.0 }},
          index: {{ forloop.index }}
        }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ]
    }
  });

  {% elsif request.page_type == 'cart' %}

  window.dataLayer.push({ ecommerce: null });
  window.dataLayer.push({
    event: 'view_cart',
    ecommerce: {
      currency: {{ shop.currency | json }},
      value: {{ cart.total_price | divided_by: 100.0 }},
      items: [
        {% for item in cart.items %}
        {
          item_id: {{ item.sku | default: item.variant_id | json }},
          item_name: {{ item.product.title | json }},
          item_brand: {{ item.vendor | json }},
          item_category: {{ item.product.type | json }},
          item_variant: {{ item.variant.title | json }},
          price: {{ item.price | divided_by: 100.0 }},
          quantity: {{ item.quantity }}
        }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ]
    }
  });

  {% endif %}
</script>
