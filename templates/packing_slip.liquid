<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ order.name }} — Vito Piano</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700&family=Chivo+Mono:wght@400;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      background: #ffffff;
      color: #1C1C1A;
      font-size: 10pt;
      line-height: 1.5;
      max-width: 820px;
      margin: 0 auto;
    }

    /* ── HEADER ─────────────────────────────────────── */
    .ps-header {
      border-top: 5px solid #0C4433;
      padding: 2rem 2.4rem 1.8rem;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      border-bottom: 1px solid rgba(12, 68, 51, 0.14);
    }

    .ps-brand__logo {
      height: 3.2rem;
      width: auto;
      display: block;
    }

    .ps-brand__name {
      font-family: 'Chivo Mono', monospace;
      font-size: 1.3rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: #0C4433;
    }

    .ps-order-meta {
      text-align: right;
      font-family: 'Chivo Mono', monospace;
      font-size: 0.75rem;
      letter-spacing: 0.08em;
      color: rgba(28, 28, 26, 0.45);
      line-height: 2;
    }

    .ps-order-meta__number {
      font-size: 1.05rem;
      font-weight: 700;
      color: #1C1C1A;
      letter-spacing: 0.06em;
      display: block;
      line-height: 1.2;
      margin-bottom: 0.3rem;
    }

    .ps-order-meta__status {
      display: inline-block;
      margin-top: 0.4rem;
      padding: 0.15rem 0.6rem;
      background: rgba(12, 68, 51, 0.07);
      color: #0C4433;
      font-size: 0.65rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      font-weight: 700;
    }

    /* ── ADDRESSES ──────────────────────────────────── */
    .ps-addresses {
      display: grid;
      grid-template-columns: 1fr 1fr;
      padding: 1.8rem 2.4rem;
      border-bottom: 1px solid rgba(12, 68, 51, 0.10);
      gap: 2rem;
    }

    .ps-addresses.single {
      grid-template-columns: 1fr;
    }

    .ps-address + .ps-address {
      padding-left: 2rem;
      border-left: 1px solid rgba(12, 68, 51, 0.10);
    }

    .ps-label {
      font-family: 'Chivo Mono', monospace;
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: rgba(12, 68, 51, 0.55);
      display: block;
      margin-bottom: 0.7rem;
    }

    .ps-address p {
      font-size: 0.88rem;
      line-height: 1.65;
      color: rgba(28, 28, 26, 0.75);
    }

    .ps-address__name {
      font-weight: 600;
      color: #1C1C1A;
    }

    /* ── ITEMS TABLE ────────────────────────────────── */
    .ps-items {
      padding: 1.6rem 2.4rem 0;
    }

    .ps-table {
      width: 100%;
      border-collapse: collapse;
    }

    .ps-table thead tr {
      border-bottom: 2px solid #0C4433;
    }

    .ps-table th {
      font-family: 'Chivo Mono', monospace;
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: rgba(12, 68, 51, 0.55);
      padding: 0 0 0.7rem;
      text-align: left;
    }

    .ps-table th.align-right { text-align: right; }

    .ps-table tbody tr {
      border-bottom: 1px solid rgba(12, 68, 51, 0.08);
    }

    .ps-table tbody tr:last-child {
      border-bottom: none;
    }

    .ps-table td {
      padding: 1rem 0;
      vertical-align: top;
    }

    .ps-table td.align-right {
      text-align: right;
      font-family: 'Chivo Mono', monospace;
      font-size: 0.82rem;
      color: rgba(28, 28, 26, 0.70);
      white-space: nowrap;
    }

    .ps-item__img-cell {
      width: 4.8rem;
      padding-right: 1rem;
    }

    .ps-item__img {
      width: 3.6rem;
      height: 3.6rem;
      object-fit: cover;
      display: block;
      border: 1px solid rgba(12, 68, 51, 0.10);
    }

    .ps-item__img-placeholder {
      width: 3.6rem;
      height: 3.6rem;
      background: rgba(12, 68, 51, 0.04);
      display: block;
    }

    .ps-item__title {
      font-weight: 600;
      color: #1C1C1A;
      font-size: 0.92rem;
      display: block;
    }

    .ps-item__variant {
      font-size: 0.78rem;
      color: rgba(28, 28, 26, 0.45);
      font-family: 'Chivo Mono', monospace;
      letter-spacing: 0.07em;
      display: block;
      margin-top: 0.25rem;
    }

    .ps-item__sku {
      font-size: 0.68rem;
      color: rgba(28, 28, 26, 0.30);
      font-family: 'Chivo Mono', monospace;
      letter-spacing: 0.07em;
      display: block;
      margin-top: 0.15rem;
    }

    /* ── TOTALS ─────────────────────────────────────── */
    .ps-totals {
      padding: 1.2rem 2.4rem 1.6rem;
      display: flex;
      justify-content: flex-end;
      border-top: 1px solid rgba(12, 68, 51, 0.10);
      margin-top: 0.2rem;
    }

    .ps-totals__table {
      width: 24rem;
      border-collapse: collapse;
    }

    .ps-totals__table td {
      padding: 0.3rem 0;
      font-size: 0.85rem;
      color: rgba(28, 28, 26, 0.60);
    }

    .ps-totals__table td:last-child {
      text-align: right;
      font-family: 'Chivo Mono', monospace;
      font-size: 0.82rem;
      white-space: nowrap;
    }

    .ps-totals__table .ps-totals__discount td {
      color: rgba(12, 68, 51, 0.80);
    }

    .ps-totals__table .ps-totals__total td {
      font-family: 'Chivo Mono', monospace;
      font-size: 0.95rem;
      font-weight: 700;
      color: #0C4433;
      border-top: 2px solid #0C4433;
      padding-top: 0.7rem;
      margin-top: 0.5rem;
      letter-spacing: 0.06em;
    }

    /* ── NOTE DEL PEDIDO ────────────────────────────── */
    .ps-note {
      margin: 0 2.4rem 1.6rem;
      padding: 1rem 1.2rem;
      background: rgba(12, 68, 51, 0.04);
      border-left: 2px solid rgba(12, 68, 51, 0.22);
    }

    .ps-note p {
      font-size: 0.85rem;
      color: rgba(28, 28, 26, 0.65);
      font-style: italic;
      margin-top: 0.5rem;
    }

    /* ── FOOTER ─────────────────────────────────────── */
    .ps-footer {
      margin-top: 2rem;
      padding: 1.6rem 2.4rem 2rem;
      border-top: 1px solid rgba(12, 68, 51, 0.12);
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
    }

    .ps-footer__message {
      font-size: 0.88rem;
      color: rgba(28, 28, 26, 0.45);
      line-height: 1.7;
    }

    .ps-footer__signature {
      display: block;
      font-size: 1rem;
      font-style: italic;
      color: rgba(12, 68, 51, 0.50);
      margin-top: 0.3rem;
      letter-spacing: 0.02em;
    }

    .ps-footer__contact {
      text-align: right;
      font-family: 'Chivo Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.10em;
      color: rgba(28, 28, 26, 0.30);
      line-height: 2;
    }

    /* ── PRINT ──────────────────────────────────────── */
    @media print {
      body { font-size: 9pt; max-width: 100%; }
      .ps-header { padding: 1.4rem 1.8rem 1.2rem; }
      .ps-addresses, .ps-items, .ps-totals,
      .ps-note, .ps-footer { padding-left: 1.8rem; padding-right: 1.8rem; }
    }
  </style>
</head>
<body>

  <!-- HEADER -->
  <header class="ps-header">
    <div class="ps-brand">
      <img src="https://cdn.shopify.com/s/files/1/0680/0490/5276/files/VP_Logo_Logo_terciario-19.png?v=1778083430" alt="Vito Piano" class="ps-brand__logo">
    </div>
    <div class="ps-order-meta">
      <span class="ps-order-meta__number">{{ order.name }}</span>
      {{ order.created_at | date: "%-d de %B de %Y" }}<br>
      {% if order.financial_status == 'paid' %}
        <span class="ps-order-meta__status">Pago confirmado</span>
      {% elsif order.financial_status == 'pending' %}
        <span class="ps-order-meta__status">Pago pendiente</span>
      {% elsif order.financial_status == 'partially_paid' %}
        <span class="ps-order-meta__status">Pago parcial</span>
      {% endif %}
    </div>
  </header>

  <!-- ADDRESSES -->
  {% assign same_address = true %}
  {% if order.billing_address and order.shipping_address %}
    {% if order.shipping_address.address1 != order.billing_address.address1
       or order.shipping_address.city != order.billing_address.city %}
      {% assign same_address = false %}
    {% endif %}
  {% endif %}

  <section class="ps-addresses{% if same_address %} single{% endif %}">
    {% if order.shipping_address %}
    <div class="ps-address">
      <span class="ps-label">Enviar a</span>
      <p>
        <span class="ps-address__name">{{ order.shipping_address.name }}</span><br>
        {{ order.shipping_address.address1 }}
        {% if order.shipping_address.address2 != blank %}<br>{{ order.shipping_address.address2 }}{% endif %}<br>
        {{ order.shipping_address.city }}{% if order.shipping_address.zip != blank %}, {{ order.shipping_address.zip }}{% endif %}<br>
        {{ order.shipping_address.country }}
        {% if order.shipping_address.phone != blank %}<br>{{ order.shipping_address.phone }}{% endif %}
      </p>
    </div>
    {% endif %}

    {% unless same_address %}
    {% if order.billing_address %}
    <div class="ps-address">
      <span class="ps-label">Facturar a</span>
      <p>
        <span class="ps-address__name">{{ order.billing_address.name }}</span><br>
        {{ order.billing_address.address1 }}
        {% if order.billing_address.address2 != blank %}<br>{{ order.billing_address.address2 }}{% endif %}<br>
        {{ order.billing_address.city }}{% if order.billing_address.zip != blank %}, {{ order.billing_address.zip }}{% endif %}<br>
        {{ order.billing_address.country }}
        {% if order.billing_address.phone != blank %}<br>{{ order.billing_address.phone }}{% endif %}
      </p>
    </div>
    {% endif %}
    {% endunless %}
  </section>

  <!-- ITEMS -->
  <section class="ps-items">
    <table class="ps-table">
      <thead>
        <tr>
          <th colspan="2">Artículo</th>
          <th class="align-right">Cant.</th>
          <th class="align-right">Precio unit.</th>
          <th class="align-right">Total</th>
        </tr>
      </thead>
      <tbody>
        {% for item in order.line_items %}
        <tr>
          <td class="ps-item__img-cell">
            {% if item.image %}
              <img src="{{ item.image | image_url: width: 72 }}" alt="{{ item.title }}" class="ps-item__img">
            {% else %}
              <span class="ps-item__img-placeholder"></span>
            {% endif %}
          </td>
          <td>
            <span class="ps-item__title">{{ item.title }}</span>
            {% if item.variant_title != blank and item.variant_title != 'Default Title' %}
              <span class="ps-item__variant">{{ item.variant_title | upcase }}</span>
            {% endif %}
            {% if item.sku != blank %}
              <span class="ps-item__sku">REF {{ item.sku }}</span>
            {% endif %}
          </td>
          <td class="align-right">{{ item.quantity }}</td>
          <td class="align-right">{{ item.price | money }}</td>
          <td class="align-right">{{ item.price | times: item.quantity | money }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </section>

  <!-- TOTALS -->
  <div class="ps-totals">
    <table class="ps-totals__table">
      <tr>
        <td>Subtotal</td>
        <td>{{ order.subtotal_price | money }}</td>
      </tr>
      {% for shipping_line in order.shipping_lines %}
      <tr>
        <td>Envío — {{ shipping_line.title }}</td>
        <td>{{ shipping_line.price | money }}</td>
      </tr>
      {% endfor %}
      {% if order.total_discounts > 0 %}
      <tr class="ps-totals__discount">
        <td>Descuento aplicado</td>
        <td>− {{ order.total_discounts | money }}</td>
      </tr>
      {% endif %}
      {% if order.total_tax > 0 %}
      <tr>
        <td>Impuestos</td>
        <td>{{ order.total_tax | money }}</td>
      </tr>
      {% endif %}
      <tr class="ps-totals__total">
        <td>Total</td>
        <td>{{ order.total_price | money }}</td>
      </tr>
    </table>
  </div>

  <!-- NOTA DEL PEDIDO -->
  {% if order.note != blank %}
  <div class="ps-note">
    <span class="ps-label">Nota del pedido</span>
    <p>{{ order.note }}</p>
  </div>
  {% endif %}

  <!-- FOOTER -->
  <footer class="ps-footer">
    <div class="ps-footer__message">
      Cada prenda que llega a tus manos fue hecha con tiempo y atención.
      <em class="ps-footer__signature">piano, piano.</em>
    </div>
    <div class="ps-footer__contact">
      info@vitopiano.com<br>
      vitopiano.com
    </div>
  </footer>

</body>
</html>
