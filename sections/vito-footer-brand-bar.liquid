<div class="vp-fbbar-outer">
  <div class="vp-fbbar page-width">
    {%- if settings.logo != blank -%}
      <div class="vp-fbbar__watermark" aria-hidden="true">
        {{ settings.logo | image_url: width: 900 | image_tag:
          alt: '',
          loading: 'lazy',
          class: 'vp-fbbar__watermark-img'
        }}
      </div>
    {%- endif -%}
    <p class="vp-fbbar__copy">© {{ 'now' | date: '%Y' }} Vito Piano — Hecho en Colombia, con alma italiana.</p>
  </div>
</div>

<style>
  .vp-fbbar-outer {
    background: #F7F2EB;
    padding: 2.4rem 1.6rem 3.2rem;
    border-top: 1px solid rgba(12, 68, 51, 0.10);
  }

  .vp-fbbar {
    position: relative;
    overflow: hidden;
    background: #EDE8DF;
    border: 1px solid rgba(12, 68, 51, 0.13);
    padding: 5.6rem 2rem 4.8rem;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .vp-fbbar__watermark {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    user-select: none;
  }

  .vp-fbbar__watermark-img {
    width: 62%;
    max-width: 420px;
    height: auto;
    opacity: 0.07;
    object-fit: contain;
    display: block;
  }

  .vp-fbbar__copy {
    font-family: 'Chivo Mono', 'Courier New', monospace;
    font-size: 0.9rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(12, 68, 51, 0.5);
    margin: 0;
    position: relative;
    z-index: 1;
  }
</style>

{% schema %}
{
  "name": "Footer — Barra de marca",
  "settings": [],
  "enabled_on": {
    "groups": ["footer"]
  },
  "presets": [
    {
      "name": "Footer — Barra de marca"
    }
  ]
}
{% endschema %}
