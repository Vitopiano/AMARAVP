{%- if section.settings.enabled -%}
<style>
  .vp-popup-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 10000;
    background: rgba(12, 68, 51, 0.80);
    align-items: center;
    justify-content: center;
    padding: 2rem;
    backdrop-filter: blur(3px);
  }

  .vp-popup-overlay.is-active {
    display: flex;
    animation: vpFadeIn 0.4s ease forwards;
  }

  @keyframes vpFadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .vp-popup {
    background: #FCF9F5;
    max-width: 58rem;
    width: 100%;
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    animation: vpSlideUp 0.4s ease forwards;
  }

  @keyframes vpSlideUp {
    from { transform: translateY(2.4rem); opacity: 0; }
    to   { transform: translateY(0); opacity: 1; }
  }

  @media screen and (min-width: 750px) {
    .vp-popup {
      grid-template-columns: 1fr 1fr;
    }
  }

  .vp-popup__close {
    position: absolute;
    top: 1.4rem;
    right: 1.4rem;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 2.2rem;
    color: rgba(252, 249, 245, 0.55);
    line-height: 1;
    z-index: 10;
    width: 3.2rem;
    height: 3.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
    padding: 0;
  }

  .vp-popup__close:hover {
    color: #FCF9F5;
  }

  /* --- Panel izquierdo: verde botella --- */
  .vp-popup__left {
    background: #0C4433;
    padding: 4.8rem 3.2rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    position: relative;
    overflow: hidden;
    min-height: 28rem;
  }

  /* Marca de agua — logo */
  .vp-popup__watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 88%;
    pointer-events: none;
    user-select: none;
  }

  .vp-popup__watermark-img {
    width: 100%;
    height: auto;
    opacity: 0.09;
    object-fit: contain;
    display: block;
    filter: brightness(10);
  }

  .vp-popup__left-content {
    position: relative;
    z-index: 1;
  }

  .vp-popup__eyebrow {
    font-family: 'Chivo Mono', monospace;
    font-size: 0.9rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(197, 234, 255, 0.75);
    margin: 0 0 1.2rem;
  }

  .vp-popup__heading {
    font-family: 'Decofast', 'Bricolage Grotesque', serif;
    font-size: 3.2rem;
    line-height: 1.05;
    font-weight: 400;
    color: #FCF9F5;
    margin: 0 0 1.6rem;
    letter-spacing: 0.04em;
  }

  .vp-popup__subtext {
    font-size: 1.35rem;
    color: rgba(252, 249, 245, 0.70);
    margin: 0;
    line-height: 1.65;
  }

  .vp-popup__offer {
    font-family: 'Chivo Mono', monospace;
    font-size: 0.9rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: rgba(197, 234, 255, 0.60);
    margin: 2rem 0 0;
    padding-top: 1.6rem;
    border-top: 1px solid rgba(252, 249, 245, 0.10);
  }

  /* --- Panel derecho: crema --- */
  .vp-popup__right {
    padding: 4.8rem 3.2rem;
    background: #FCF9F5;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .vp-popup__form-title {
    font-family: 'Chivo Mono', monospace;
    font-size: 0.9rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(12, 68, 51, 0.45);
    margin: 0 0 2.4rem;
  }

  .vp-popup__field {
    margin-bottom: 1.4rem;
  }

  .vp-popup__input,
  .vp-popup__select {
    width: 100%;
    border: 1px solid rgba(12, 68, 51, 0.30);
    background: transparent;
    padding: 1.2rem 1.4rem;
    font-size: 1.4rem;
    border-radius: 0;
    color: #1C1C1A;
    font-family: 'Chivo Mono', monospace;
    letter-spacing: 0.03em;
    outline: none;
    transition: border-color 0.25s;
    -webkit-appearance: none;
    appearance: none;
    box-sizing: border-box;
  }

  .vp-popup__input::placeholder {
    color: rgba(28, 28, 26, 0.35);
  }

  .vp-popup__input:focus,
  .vp-popup__select:focus {
    border-color: #0C4433;
  }

  .vp-popup__birthday-label {
    font-family: 'Chivo Mono', monospace;
    font-size: 0.9rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: rgba(12, 68, 51, 0.45);
    margin: 0 0 0.8rem;
    display: block;
  }

  .vp-popup__birthday-fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.8rem;
    margin-bottom: 2.8rem;
  }

  .vp-popup__submit {
    width: 100%;
    background: #0C4433;
    color: #FCF9F5;
    border: none;
    padding: 1.5rem 2rem;
    font-family: 'Chivo Mono', monospace;
    font-size: 1.0rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color 0.25s;
    border-radius: 0;
    margin-bottom: 1.6rem;
  }

  .vp-popup__submit:hover {
    background: #431424;
  }

  .vp-popup__disclaimer {
    font-size: 1.0rem;
    color: rgba(28, 28, 26, 0.35);
    margin: 0;
    line-height: 1.6;
    font-family: 'Chivo Mono', monospace;
  }

  .vp-popup__success {
    text-align: center;
    padding: 2.4rem 0;
  }

  .vp-popup__success p {
    color: #0C4433;
    font-family: 'Chivo Mono', monospace;
    font-size: 1.3rem;
    letter-spacing: 0.06em;
    line-height: 1.6;
    margin: 0;
  }

  .vp-popup__error {
    color: #E25027;
    font-size: 1.1rem;
    font-family: 'Chivo Mono', monospace;
    margin: 0.5rem 0 0;
    display: block;
  }

  @media screen and (max-width: 749px) {
    .vp-popup__left {
      padding: 3.6rem 2.4rem 2.8rem;
      min-height: 22rem;
    }

    .vp-popup__right {
      padding: 2.8rem 2.4rem 3.2rem;
    }

    .vp-popup__heading {
      font-size: 2.4rem;
    }

    .vp-popup__watermark {
      font-size: clamp(4.5rem, 22vw, 7rem);
    }
  }
</style>

<div id="vp-popup-overlay" class="vp-popup-overlay" role="dialog" aria-modal="true" aria-labelledby="vp-popup-heading">
  <div class="vp-popup">
    <button class="vp-popup__close" id="vp-popup-close" aria-label="Cerrar">&#215;</button>

    <div class="vp-popup__left">
      {%- if settings.logo != blank -%}
        <div class="vp-popup__watermark" aria-hidden="true">
          {{ settings.logo | image_url: width: 800 | image_tag:
            alt: '',
            loading: 'lazy',
            class: 'vp-popup__watermark-img'
          }}
        </div>
      {%- endif -%}
      <div class="vp-popup__left-content">
        <p class="vp-popup__eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 class="vp-popup__heading" id="vp-popup-heading">{{ section.settings.heading }}</h2>
        <p class="vp-popup__subtext">{{ section.settings.subtext }}</p>
        {%- if section.settings.offer_line != blank -%}
          <p class="vp-popup__offer">{{ section.settings.offer_line }}</p>
        {%- endif -%}
      </div>
    </div>

    <div class="vp-popup__right">
      {%- form 'customer', id: 'vp-popup-form', class: 'vp-popup__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter,vito-piano-10off">
        <input type="hidden" name="contact[note]" id="vp-birthday-note" value="">

        {%- if form.posted_successfully? -%}
          <div class="vp-popup__success">
            <p>{{ section.settings.success_message }}</p>
          </div>
        {%- else -%}
          {%- if section.settings.form_title != blank -%}
            <p class="vp-popup__form-title">{{ section.settings.form_title }}</p>
          {%- endif -%}

          <div class="vp-popup__field">
            <input
              type="text"
              name="contact[first_name]"
              id="vp-popup-name"
              class="vp-popup__input"
              placeholder="{{ section.settings.name_placeholder }}"
              autocomplete="given-name"
            >
          </div>

          <div class="vp-popup__field">
            <input
              type="email"
              name="contact[email]"
              id="vp-popup-email"
              class="vp-popup__input"
              placeholder="{{ section.settings.email_placeholder }}"
              required
              autocomplete="email"
              value="{{ form.email }}"
            >
            {%- if form.errors contains 'email' -%}
              <span class="vp-popup__error">{{ form.errors.messages.email }}</span>
            {%- endif -%}
          </div>

          <label class="vp-popup__birthday-label" for="vp-popup-month">
            {{ section.settings.birthday_label }}
          </label>
          <div class="vp-popup__birthday-fields">
            <select id="vp-popup-month" class="vp-popup__select" aria-label="Mes de cumpleaños">
              <option value="">Mes</option>
              <option value="01">Enero</option>
              <option value="02">Febrero</option>
              <option value="03">Marzo</option>
              <option value="04">Abril</option>
              <option value="05">Mayo</option>
              <option value="06">Junio</option>
              <option value="07">Julio</option>
              <option value="08">Agosto</option>
              <option value="09">Septiembre</option>
              <option value="10">Octubre</option>
              <option value="11">Noviembre</option>
              <option value="12">Diciembre</option>
            </select>
            <select id="vp-popup-day" class="vp-popup__select" aria-label="Día de cumpleaños">
              <option value="">Día</option>
              {%- for i in (1..31) -%}
                <option value="{{ i | prepend: '00' | slice: -2, 2 }}">{{ i }}</option>
              {%- endfor -%}
            </select>
          </div>

          <button type="submit" class="vp-popup__submit">
            {{ section.settings.button_label }}
          </button>

          <p class="vp-popup__disclaimer">{{ section.settings.disclaimer }}</p>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</div>

<script>
(function () {
  var STORAGE_KEY = 'vp_popup_v1';
  var DELAY_MS = {{ section.settings.delay_seconds | times: 1000 }};
  var RESHOW_DAYS = 30;

  function shouldShow() {
    try {
      var ts = localStorage.getItem(STORAGE_KEY);
      if (!ts) return true;
      return (Date.now() - parseInt(ts, 10)) / 86400000 > RESHOW_DAYS;
    } catch (e) {
      return true;
    }
  }

  function dismiss() {
    try { localStorage.setItem(STORAGE_KEY, String(Date.now())); } catch (e) {}
    var el = document.getElementById('vp-popup-overlay');
    if (el) el.classList.remove('is-active');
  }

  document.addEventListener('DOMContentLoaded', function () {
    if (!shouldShow()) return;

    var overlay = document.getElementById('vp-popup-overlay');
    if (!overlay) return;

    setTimeout(function () {
      overlay.classList.add('is-active');
    }, DELAY_MS);

    var closeBtn = document.getElementById('vp-popup-close');
    if (closeBtn) closeBtn.addEventListener('click', dismiss);

    overlay.addEventListener('click', function (e) {
      if (e.target === overlay) dismiss();
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') dismiss();
    });

    var form = document.getElementById('vp-popup-form');
    if (form) {
      form.addEventListener('submit', function () {
        var month = document.getElementById('vp-popup-month');
        var day = document.getElementById('vp-popup-day');
        var noteField = document.getElementById('vp-birthday-note');
        var tagsField = form.querySelector('input[name="contact[tags]"]');
        if (month && day && month.value && day.value) {
          var bdayTag = 'birthday-' + month.value + '-' + day.value;
          if (noteField) noteField.value = 'Cumpleanos: ' + month.value + '/' + day.value;
          if (tagsField) tagsField.value = tagsField.value + ',' + bdayTag;
        }
      });
    }
  });

  {%- if form.posted_successfully? -%}
  try { localStorage.setItem('vp_popup_v1', String(Date.now())); } catch (e) {}
  {%- endif -%}
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Popup Newsletter",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Activar popup",
      "default": true
    },
    {
      "type": "range",
      "id": "delay_seconds",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "s",
      "label": "Demora antes de mostrar",
      "default": 5
    },
    {
      "type": "header",
      "content": "Panel izquierdo"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto eyebrow",
      "default": "Bienvenido al mundo"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Vito Piano"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtexto",
      "default": "Únete al círculo de hombres y mujeres que visten con propósito."
    },
    {
      "type": "text",
      "id": "offer_line",
      "label": "Línea de oferta (opcional)",
      "default": "Como bienvenida, un 10% en tu primera prenda."
    },
    {
      "type": "header",
      "content": "Formulario"
    },
    {
      "type": "text",
      "id": "form_title",
      "label": "Título del formulario (dejar vacío para ocultar)",
      "default": ""
    },
    {
      "type": "text",
      "id": "name_placeholder",
      "label": "Placeholder nombre",
      "default": "Tu nombre"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Placeholder email",
      "default": "tu@email.com"
    },
    {
      "type": "text",
      "id": "birthday_label",
      "label": "Etiqueta de cumpleaños",
      "default": "Fecha de cumpleaños (opcional)"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto del botón",
      "default": "Unirme al mundo Vito Piano"
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Aviso legal",
      "default": "Al suscribirte aceptas recibir comunicaciones de Vito Piano. Puedes darte de baja cuando quieras."
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Mensaje de éxito",
      "default": "Bienvenido. Revisa tu correo — tu 10% te espera."
    }
  ],
  "presets": [
    {
      "name": "Popup Newsletter"
    }
  ]
}
{% endschema %}
