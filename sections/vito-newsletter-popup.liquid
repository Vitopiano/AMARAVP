{%- if section.settings.enabled -%}
<style>
  .vp-popup-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 10000;
    background: rgba(12, 68, 51, 0.78);
    align-items: center;
    justify-content: center;
    padding: 2rem;
    backdrop-filter: blur(2px);
  }

  .vp-popup-overlay.is-active {
    display: flex;
    animation: vpFadeIn 0.35s ease forwards;
  }

  @keyframes vpFadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .vp-popup {
    background: #FCF9F5;
    max-width: 56rem;
    width: 100%;
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    animation: vpSlideUp 0.35s ease forwards;
  }

  @keyframes vpSlideUp {
    from { transform: translateY(2rem); opacity: 0; }
    to   { transform: translateY(0); opacity: 1; }
  }

  @media screen and (min-width: 750px) {
    .vp-popup {
      grid-template-columns: 1fr 1fr;
    }
  }

  .vp-popup__close {
    position: absolute;
    top: 1.4rem;
    right: 1.4rem;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 2.2rem;
    color: #431424;
    line-height: 1;
    z-index: 2;
    width: 3.2rem;
    height: 3.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
    padding: 0;
  }

  .vp-popup__close:hover {
    color: #0C4433;
  }

  /* --- Panel izquierdo: verde botella --- */
  .vp-popup__left {
    background: #0C4433;
    padding: 4.8rem 3.2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .vp-popup__eyebrow {
    font-family: 'Chivo Mono', monospace;
    font-size: 1.0rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(252, 249, 245, 0.65);
    margin: 0 0 1.4rem;
  }

  .vp-popup__heading {
    font-size: 3.8rem;
    line-height: 1.05;
    font-weight: 400;
    color: #FCF9F5;
    margin: 0 0 1.6rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* Logo + offer agrupados: inline-flex para igualar anchos */
  .vp-popup__brand {
    display: inline-flex;
    flex-direction: column;
    align-items: stretch;
    margin: 0 0 1.6rem;
  }

  .vp-popup__logo {
    display: block;
    width: 100%;
    margin: 0 0 1.0rem;
    filter: brightness(10);
    opacity: 0.92;
  }

  .vp-popup__offer {
    display: block;
    font-family: 'Chivo Mono', monospace;
    font-size: 1.2rem;
    font-weight: 700;
    color: rgba(197, 234, 255, 0.80);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    white-space: nowrap;
    margin: 0;
  }

  .vp-popup__subtext {
    font-size: 1.3rem;
    color: rgba(252, 249, 245, 0.65);
    margin: 0;
    line-height: 1.65;
  }

  .vp-popup__whisper {
    margin-top: auto;
    padding-top: 2.4rem;
    font-family: 'Bricolage Grotesque', Georgia, serif;
    font-style: italic;
    font-size: 1.1rem;
    font-weight: 300;
    line-height: 1.6;
    color: rgba(252, 249, 245, 0.28);
    letter-spacing: 0;
  }

  /* --- Panel derecho: crema --- */
  .vp-popup__right {
    padding: 4.8rem 3.2rem;
    background: #FCF9F5;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .vp-popup__form-title {
    font-family: 'Chivo Mono', monospace;
    font-size: 1.0rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(28, 28, 26, 0.45);
    margin: 0 0 2.4rem;
  }

  .vp-popup__field {
    margin-bottom: 1.6rem;
  }

  .vp-popup__input,
  .vp-popup__select {
    width: 100%;
    border: 1.5px solid #431424;
    background: transparent;
    padding: 1.2rem 1.4rem;
    font-size: 1.4rem;
    border-radius: 0;
    color: rgba(67, 20, 36, 0.50);
    font-family: 'Chivo Mono', monospace;
    letter-spacing: 0.03em;
    outline: none;
    transition: border-color 0.25s;
    -webkit-appearance: none;
    appearance: none;
    box-sizing: border-box;
  }

  .vp-popup__input::placeholder {
    color: rgba(67, 20, 36, 0.40);
  }

  .vp-popup__input:focus,
  .vp-popup__select:focus {
    border-color: #431424;
    color: rgba(67, 20, 36, 0.75);
  }

  .vp-popup__birthday-label {
    font-family: 'Chivo Mono', monospace;
    font-size: 1.0rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(67, 20, 36, 0.50);
    margin: 0 0 0.8rem;
    display: block;
  }

  .vp-popup__birthday-fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.8rem;
    margin-bottom: 2.0rem;
  }

  .vp-popup__interests {
    display: flex;
    gap: 1.6rem;
    margin-bottom: 2.4rem;
  }

  .vp-popup__interest-option {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    cursor: pointer;
    font-family: 'Chivo Mono', monospace;
    font-size: 1.0rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(67, 20, 36, 0.65);
    user-select: none;
  }

  .vp-popup__interest-option input[type="radio"] {
    -webkit-appearance: none;
    appearance: none;
    width: 1.4rem;
    height: 1.4rem;
    border: 1.5px solid rgba(67, 20, 36, 0.45);
    border-radius: 50%;
    flex-shrink: 0;
    cursor: pointer;
    transition: background-color 0.2s, border-color 0.2s;
  }

  .vp-popup__interest-option input[type="radio"]:checked {
    background-color: #431424;
    border-color: #431424;
  }

  .vp-popup__interest-option:has(input:checked) {
    color: rgba(67, 20, 36, 0.90);
  }

  .vp-popup__submit {
    width: 100%;
    background: #0C4433;
    color: #FCF9F5;
    border: none;
    padding: 1.4rem 2rem;
    font-family: 'Chivo Mono', monospace;
    font-size: 1.1rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color 0.25s;
    border-radius: 0;
    margin-bottom: 1.4rem;
  }

  .vp-popup__submit:hover {
    background: #431424;
  }

  .vp-popup__disclaimer {
    font-family: 'Bricolage Grotesque', Georgia, serif;
    font-style: italic;
    font-size: 1.1rem;
    font-weight: 300;
    color: rgba(12, 68, 51, 0.45);
    margin: 0;
    line-height: 1.6;
    letter-spacing: 0;
  }

  .vp-popup__success {
    text-align: center;
    padding: 2.4rem 0;
  }

  .vp-popup__success p {
    color: #0C4433;
    font-family: 'Chivo Mono', monospace;
    font-size: 1.3rem;
    letter-spacing: 0.06em;
    line-height: 1.6;
    margin: 0;
  }

  .vp-popup__error {
    color: #E25027;
    font-size: 1.2rem;
    font-family: 'Chivo Mono', monospace;
    margin: 0.6rem 0 0;
    display: block;
  }

  @media screen and (max-width: 749px) {
    .vp-popup__left {
      padding: 4rem 2.4rem 2.8rem;
    }

    .vp-popup__right {
      padding: 2.8rem 2.4rem 3.2rem;
    }

    .vp-popup__heading {
      font-size: 2.5rem;
    }

    .vp-popup__discount {
      font-size: 4rem;
    }
  }
</style>

<div id="vp-popup-overlay" class="vp-popup-overlay" role="dialog" aria-modal="true" aria-labelledby="vp-popup-heading">
  <div class="vp-popup">
    <button class="vp-popup__close" id="vp-popup-close" aria-label="Cerrar popup">&#215;</button>

    <div class="vp-popup__left">
      <p class="vp-popup__eyebrow">Bienvenido al mundo</p>
      <div class="vp-popup__brand">
        <img
          src="https://cdn.shopify.com/s/files/1/0680/0490/5276/files/VP_Logo_Logo_terciario-20.png?v=1777766396"
          alt="Vito Piano"
          id="vp-popup-heading"
          class="vp-popup__logo"
          loading="eager"
        >
        <span class="vp-popup__offer">10% en tu primera compra</span>
      </div>
      <p class="vp-popup__subtext">Únete a un círculo de personas que eligen con propósito.</p>
    </div>

    <div class="vp-popup__right">
      {%- form 'customer', id: 'vp-popup-form', class: 'vp-popup__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter,vito-piano-10off">
        <input type="hidden" name="contact[note]" id="vp-birthday-note" value="">

        {%- if form.posted_successfully? -%}
          <div class="vp-popup__success">
            <p>¡Bienvenido! Revisa tu correo — tu código de 10% estará esperándote.</p>
          </div>
        {%- else -%}

          <div class="vp-popup__field">
            <input
              type="text"
              name="contact[first_name]"
              id="vp-popup-name"
              class="vp-popup__input"
              placeholder="{{ section.settings.name_placeholder }}"
              autocomplete="given-name"
            >
          </div>

          <div class="vp-popup__field">
            <input
              type="email"
              name="contact[email]"
              id="vp-popup-email"
              class="vp-popup__input"
              placeholder="{{ section.settings.email_placeholder }}"
              required
              autocomplete="email"
              value="{{ form.email }}"
            >
            {%- if form.errors contains 'email' -%}
              <span class="vp-popup__error">{{ form.errors.messages.email }}</span>
            {%- endif -%}
          </div>

          <label class="vp-popup__birthday-label" for="vp-popup-month">
            {{ section.settings.birthday_label }}
          </label>
          <div class="vp-popup__birthday-fields">
            <select id="vp-popup-month" class="vp-popup__select" aria-label="Mes de cumpleaños">
              <option value="">Mes</option>
              <option value="01">Enero</option>
              <option value="02">Febrero</option>
              <option value="03">Marzo</option>
              <option value="04">Abril</option>
              <option value="05">Mayo</option>
              <option value="06">Junio</option>
              <option value="07">Julio</option>
              <option value="08">Agosto</option>
              <option value="09">Septiembre</option>
              <option value="10">Octubre</option>
              <option value="11">Noviembre</option>
              <option value="12">Diciembre</option>
            </select>
            <select id="vp-popup-day" class="vp-popup__select" aria-label="Día de cumpleaños">
              <option value="">Día</option>
              {%- for i in (1..31) -%}
                <option value="{{ i | prepend: '00' | slice: -2, 2 }}">{{ i }}</option>
              {%- endfor -%}
            </select>
          </div>

          <span class="vp-popup__birthday-label" style="margin-bottom: 0.8rem; display: block;">Me interesa</span>
          <div class="vp-popup__interests">
            <label class="vp-popup__interest-option">
              <input type="radio" name="vp-interest" value="mujer"> Mujer
            </label>
            <label class="vp-popup__interest-option">
              <input type="radio" name="vp-interest" value="hombre"> Hombre
            </label>
            <label class="vp-popup__interest-option">
              <input type="radio" name="vp-interest" value="ambos" checked> Ambos
            </label>
          </div>

          <button type="submit" class="vp-popup__submit">
            Suscribirme
          </button>

          <p class="vp-popup__disclaimer">Sin ruido. Solo lo que vale: novedades, lanzamientos y acceso anticipado a nuevas piezas.</p>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</div>

<script>
(function () {
  var STORAGE_KEY = 'vp_popup_v1';
  var DELAY_MS = {{ section.settings.delay_seconds | times: 1000 }};
  var RESHOW_DAYS = 30;

  function shouldShow() {
    try {
      var ts = localStorage.getItem(STORAGE_KEY);
      if (!ts) return true;
      return (Date.now() - parseInt(ts, 10)) / 86400000 > RESHOW_DAYS;
    } catch (e) {
      return true;
    }
  }

  function dismiss() {
    try { localStorage.setItem(STORAGE_KEY, String(Date.now())); } catch (e) {}
    var el = document.getElementById('vp-popup-overlay');
    if (el) el.classList.remove('is-active');
  }

  document.addEventListener('DOMContentLoaded', function () {
    if (!shouldShow()) return;

    var overlay = document.getElementById('vp-popup-overlay');
    if (!overlay) return;

    setTimeout(function () {
      overlay.classList.add('is-active');
    }, DELAY_MS);

    var closeBtn = document.getElementById('vp-popup-close');
    if (closeBtn) closeBtn.addEventListener('click', dismiss);

    overlay.addEventListener('click', function (e) {
      if (e.target === overlay) dismiss();
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') dismiss();
    });

    var form = document.getElementById('vp-popup-form');
    if (form) {
      form.addEventListener('submit', function () {
        var month = document.getElementById('vp-popup-month');
        var day = document.getElementById('vp-popup-day');
        var noteField = document.getElementById('vp-birthday-note');
        var tagsField = form.querySelector('input[name="contact[tags]"]');
        if (month && day && month.value && day.value) {
          var bdayTag = 'birthday-' + month.value + '-' + day.value;
          if (noteField) noteField.value = 'Cumpleanos: ' + month.value + '/' + day.value;
          if (tagsField) tagsField.value = tagsField.value + ',' + bdayTag;
        }
        var interest = form.querySelector('input[name="vp-interest"]:checked');
        if (interest && interest.value && tagsField) {
          tagsField.value = tagsField.value + ',interes-' + interest.value;
        }
      });
    }
  });

  /* Marcar como visto si el form fue enviado exitosamente */
  {%- if form.posted_successfully? -%}
  try { localStorage.setItem('vp_popup_v1', String(Date.now())); } catch (e) {}
  {%- endif -%}
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Popup Newsletter",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Activar popup",
      "default": true
    },
    {
      "type": "range",
      "id": "delay_seconds",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "s",
      "label": "Demora antes de mostrar",
      "default": 5
    },
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto eyebrow",
      "default": "Bienvenido al mundo"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Vito Piano"
    },
    {
      "type": "text",
      "id": "discount_badge",
      "label": "Oferta destacada",
      "default": "10% OFF"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtexto",
      "default": "En tu primera compra. Suscríbete y únete a un círculo de hombres y mujeres que visten con propósito."
    },
    {
      "type": "header",
      "content": "Formulario"
    },
    {
      "type": "text",
      "id": "form_title",
      "label": "Título del formulario",
      "default": "Ingresa tus datos"
    },
    {
      "type": "text",
      "id": "name_placeholder",
      "label": "Placeholder nombre",
      "default": "Tu nombre"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Placeholder email",
      "default": "tu@email.com"
    },
    {
      "type": "text",
      "id": "birthday_label",
      "label": "Etiqueta de cumpleaños",
      "default": "Fecha de cumpleaños (opcional)"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto del botón",
      "default": "Suscribirme y obtener 10%"
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Aviso legal",
      "default": "Al suscribirte aceptas recibir comunicaciones de Vito Piano. Puedes darte de baja en cualquier momento."
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Mensaje de éxito",
      "default": "¡Bienvenido! Revisa tu correo — tu código de 10% estará esperándote."
    }
  ],
  "presets": [
    {
      "name": "Popup Newsletter"
    }
  ]
}
{% endschema %}
